{
  "private": true,
  "name": "@groundcover-com/groundcover-github-action",
  "type": "module",
  "version": "3.0.0",
  "description": "Export GitHub Actions workflow runs as OpenTelemetry traces to groundcover",
  "scripts": {
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write src/",
    "format:check": "prettier --check src/",
    "typecheck": "tsc --noEmit",
    "build": "rollup -c --configPlugin @rollup/plugin-typescript",
    "test": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest --collect-coverage",
    "test:ci": "cross-env NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest --collect-coverage --ci",
    "test:record": "cross-env RECORD_OCTOKIT=true NODE_OPTIONS=--experimental-vm-modules NODE_NO_WARNINGS=1 jest",
    "all": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "keywords": [
    "github-actions",
    "opentelemetry",
    "cicd",
    "traces",
    "observability"
  ],
  "author": "groundcover",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/groundcover-com/groundcover-github-action.git"
  },
  "homepage": "https://github.com/groundcover-com/groundcover-github-action",
  "bugs": {
    "url": "https://github.com/groundcover-com/groundcover-github-action/issues"
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "@grpc/grpc-js": "^1.12.0",
    "@octokit/openapi-types": "^27.0.0",
    "@octokit/request-error": "^7.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.213.0",
    "@opentelemetry/context-async-hooks": "^2.6.0",
    "@opentelemetry/core": "^2.6.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.213.0",
    "@opentelemetry/exporter-logs-otlp-proto": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.213.0",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.213.0",
    "@opentelemetry/resources": "^2.6.0",
    "@opentelemetry/sdk-logs": "^0.213.0",
    "@opentelemetry/sdk-trace-base": "^2.6.0",
    "@opentelemetry/semantic-conventions": "^1.28.0",
    "fast-glob": "^3.3.3",
    "fast-xml-parser": "^5.4.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@jest/globals": "^29.7.0",
    "@octokit/rest": "^21.1.0",
    "@octokit/types": "^13.8.0",
    "@rollup/plugin-commonjs": "^28.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.0",
    "@rollup/plugin-typescript": "^12.1.0",
    "caller-callsite": "^6.0.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.2.0",
    "jest": "^29.7.0",
    "prettier": "^3.8.3",
    "rollup": "^4.60.2",
    "rollup-plugin-license": "^3.7.1",
    "ts-jest": "^29.4.9",
    "ts-jest-resolver": "^2.0.1",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.58.2"
  },
  "engines": {
    "node": ">=24.0.0"
  }
}
